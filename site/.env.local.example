# Maczkó Fotó — környezeti változók
# Másold ezt a fájlt .env.local-ra és töltsd ki a tokennel.

# Az aláírt token a Maczkó Web form-handler szerverhez.
# Generálás (a server VPS-en, vagy ahol a .env-ben ott a SIGNING_SECRET):
#
#   cd /opt/multipro-form
#   npm run token -- \
#     --name "Maczkó Fotó" \
#     --to "maczkomark08@gmail.com" \
#     --origin "https://maczkofoto.hu" \
#     --origin "https://www.maczkofoto.hu" \
#     --origin "http://localhost:3007" \
#     --fromName "Maczkó Fotó weboldal" \
#     --subject "Új felkérés — Maczkó Fotó"
#
# A kimenetet (egy hosszú "x.y" formátumú string) illeszd ide.
NEXT_PUBLIC_FORM_TOKEN=eyJzaXRlIjoiTWFjemvDsyBGb3TDsyIsInRvIjoibWFjemtvbWFyazA4QGdtYWlsLmNvbSIsIm9yaWdpbnMiOlsiaHR0cHM6Ly9tYWN6a29mb3RvLmh1IiwiaHR0cHM6Ly93d3cubWFjemtvZm90by5odSJdLCJmcm9tTmFtZSI6Ik1hY3prw7MgRm90w7Mgd2Vib2xkYWwiLCJzdWJqZWN0UHJlZml4Ijoiw5pqIGZlbGvDqXLDqXMg4oCUIE1hY3prw7MgRm90w7MifQ.X6rh1-GQHXH0eIW8HW3vBeRkNKpAikWLwhZgxDdNkq4

# A form-handler endpoint URL-je. Hagyhatod alapértelmezetten.
NEXT_PUBLIC_FORM_ENDPOINT=https://api.maczkoweb.hu/api/contact

# Az oldal éles URL-je — ezt használja a sitemap.xml és a robots.txt.
# Alapért. https://maczkofoto.hu. Ha más domain alá deployolod, itt írd át.
NEXT_PUBLIC_SITE_URL=https://maczkofoto.hu
